{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/projects/cc-component-health/component/[id]",
      "regex": "^/projects/cc\\-component\\-health/component/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/projects/cc\\-component\\-health/component/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/projects/cc-component-health",
      "regex": "^/projects/cc\\-component\\-health(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects/cc\\-component\\-health(?:/)?$"
    },
    {
      "page": "/projects/cc-component-health/alerts",
      "regex": "^/projects/cc\\-component\\-health/alerts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects/cc\\-component\\-health/alerts(?:/)?$"
    },
    {
      "page": "/projects/cc-component-health/dashboard",
      "regex": "^/projects/cc\\-component\\-health/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects/cc\\-component\\-health/dashboard(?:/)?$"
    },
    {
      "page": "/projects/cc-component-health/setup",
      "regex": "^/projects/cc\\-component\\-health/setup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects/cc\\-component\\-health/setup(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}